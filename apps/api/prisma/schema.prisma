// Forecast-Portal BU Brachytherapie — Prisma-Schema (§3 Umsetzungsplan)
// Domänenfelder Deutsch, Enums UPPERCASE, IDs uuid, Geld Decimal(15,2) in vollem EUR.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────── ENUMS ───────────────
enum Rolle {
  AGM
  VERTRIEBSLEITER
  BU_LEITER
  ADMIN
  SUPPORT
}

enum UserStatus {
  EINGELADEN
  VERIFIZIERT
  DEAKTIVIERT
}

enum Company {
  BBD
  BBE
  BBF
  BMW
}

enum E1Kategorie {
  IMPLANT
  OPHTHALMO
  AFTERLOADER
  OTHER
  ZENTRAL
}

enum KennzahlTyp {
  REVENUE
}

enum BudgetStatus {
  AKTIV
  HISTORISIERT
}

enum BudgetAenderungStatus {
  ENTWURF
  BEANTRAGT
  FREIGABE_VERTRIEBSLEITER
  FREIGABE_BU_LEITER
  ABGELEHNT
  AKTIV
}

enum ForecastStatus {
  OFFEN
  BESTAETIGT
  ANGEPASST
  ZURUECKGEWIESEN
  ABGESCHLOSSEN
}

enum ImportStatus {
  HOCHGELADEN
  VALIDIERT
  ABGESCHLOSSEN
  FEHLGESCHLAGEN
}

enum QuarantaeneStatus {
  OFFEN
  GEKLAERT
  VERWORFEN
}

enum QuarantaeneGrund {
  UNBEKANNTE_KOSTENSTELLE
  LAND_LEER
  UNBEKANNTES_LAND
  UNBEKANNTER_LANDNAME
  UNBEKANNTE_E1
  UNBEKANNTE_E2
  WERT_LEER
  VORZEICHEN_INKONSISTENT
  UNBEKANNTER_MONAT
  RECID_DUP_IN_DATEI
  COMPANY_UNBEKANNT
  RECID_LEER
  SCHLUESSEL_LEER
  SCHLUESSEL_DUP_IN_DATEI
  RECHNUNG_OHNE_KOPF
  DATUM_UNGUELTIG
}

enum AuditAktion {
  CREATE
  UPDATE
  DELETE
  STATUS_WECHSEL
  IMPORT
  EXPORT
  LOGIN
  LOGIN_FEHLER
  MAIL_FEHLER
}

// ─────────────── AUTH / USER ───────────────
model User {
  id                     String     @id @default(uuid())
  email                  String     @unique
  name                   String
  passwortHash           String?
  rolle                  Rolle
  status                 UserStatus @default(EINGELADEN)
  passwortWechselPflicht Boolean    @default(false)
  einladungTokenHash     String?    @unique
  einladungAblauf        DateTime?
  resetTokenHash         String?    @unique
  resetAblauf            DateTime?
  fehlversuche           Int        @default(0)
  gesperrtBis            DateTime?
  letzterLogin           DateTime?
  erstelltAm             DateTime   @default(now())
  aktualisiertAm         DateTime   @updatedAt

  verantwortungen   RegionsVerantwortung[]
  forecastVersionen ForecastVersion[]
  budgetAenderungen BudgetAenderung[]      @relation("Antragsteller")
  budgetEvents      BudgetAenderungEvent[]
  importBatches     ImportBatch[]
  sondereffekte     Sondereffekt[]

  @@index([rolle])
  @@index([status])
  @@map("user")
}

// ─────────────── STAMMDATEN ───────────────
model Region {
  code             String   @id
  bezeichnung      String
  forecastRelevant Boolean  @default(true)
  synonyme         String[] @default([])
  erstelltAm       DateTime @default(now())
  aktualisiertAm   DateTime @updatedAt

  kostenstellen     Kostenstelle[]
  verantwortungen   RegionsVerantwortung[]
  budgets           Budget[]
  budgetAenderungen BudgetAenderung[]
  forecastVersionen ForecastVersion[]
  forecastPerioden  ForecastPeriode[]

  @@map("region")
}

model Kostenstelle {
  id             String   @id @default(uuid())
  nummer         String   @unique
  bezeichnung    String
  company        Company
  istSammel      Boolean  @default(false)
  regionCode     String
  erstelltAm     DateTime @default(now())
  aktualisiertAm DateTime @updatedAt

  region      Region      @relation(fields: [regionCode], references: [code])
  istUmsaetze IstUmsatz[]

  @@index([regionCode])
  @@index([company])
  @@map("kostenstelle")
}

model RegionsVerantwortung {
  id             String    @id @default(uuid())
  userId         String
  regionCode     String
  gueltigVon     DateTime
  gueltigBis     DateTime?
  geloeschtAm    DateTime?
  erstelltAm     DateTime  @default(now())
  aktualisiertAm DateTime  @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  region Region @relation(fields: [regionCode], references: [code])

  @@index([userId])
  @@index([regionCode])
  @@index([gueltigVon, gueltigBis])
  @@map("regions_verantwortung")
}

model Land {
  isoCode        String   @id
  nameDe         String
  nameEn         String
  erstelltAm     DateTime @default(now())
  aktualisiertAm DateTime @updatedAt

  istUmsaetze       IstUmsatz[]
  budgets           Budget[]
  budgetAenderungen BudgetAenderung[]
  forecastVersionen ForecastVersion[]
  absaetze          Absatz[]
  salesFlashDetails SalesFlashDetail[]
  liefermengen      Liefermenge[]

  @@index([nameEn])
  @@map("land")
}

model ProduktgruppeE1 {
  id             String      @id @default(uuid())
  kategorie      E1Kategorie @unique
  nameDe         String
  nameEn         String
  synonyme       String[]    @default([])
  sortierung     Int         @default(0)
  erstelltAm     DateTime    @default(now())
  aktualisiertAm DateTime    @updatedAt

  e2Gruppen         ProduktgruppeE2[]
  istUmsaetze       IstUmsatz[]
  budgets           Budget[]
  budgetAenderungen BudgetAenderung[]
  forecastVersionen ForecastVersion[]
  reportEintraege   ReportEintrag[]
  salesFlashDetails SalesFlashDetail[]
  liefermengen      Liefermenge[]

  @@map("produktgruppe_e1")
}

model ProduktgruppeE2 {
  id             String   @id @default(uuid())
  name           String   @unique
  e1Id           String
  synonyme       String[] @default([])
  istPlatzhalter Boolean  @default(false)
  erstelltAm     DateTime @default(now())
  aktualisiertAm DateTime @updatedAt

  e1           ProduktgruppeE1 @relation(fields: [e1Id], references: [id])
  istUmsaetze  IstUmsatz[]
  budgets      Budget[]
  liefermengen Liefermenge[]

  @@index([e1Id])
  @@map("produktgruppe_e2")
}

// ─────────────── IST-UMSATZ ───────────────
model IstUmsatz {
  id                String      @id @default(uuid())
  recid             String      @unique
  dataareaid        String
  buchungsdatum     DateTime
  jahr              Int
  monat             Int
  kostenstelleId    String
  landId            String?
  e1Id              String
  e2Id              String?
  kostentraeger     String?
  sachkonto         String?
  postingtype       String?
  wertEur           Decimal     @db.Decimal(15, 2)
  kennzahlTyp       KennzahlTyp @default(REVENUE)
  istSondereffekt   Boolean     @default(false)
  sondereffektGrund String?
  importBatchId     String
  erstelltAm        DateTime    @default(now())
  aktualisiertAm    DateTime    @updatedAt

  kostenstelle Kostenstelle     @relation(fields: [kostenstelleId], references: [id])
  land         Land?            @relation(fields: [landId], references: [isoCode])
  e1           ProduktgruppeE1  @relation(fields: [e1Id], references: [id])
  e2           ProduktgruppeE2? @relation(fields: [e2Id], references: [id])
  importBatch  ImportBatch      @relation(fields: [importBatchId], references: [id])

  @@index([jahr, monat])
  @@index([kostenstelleId])
  @@index([landId])
  @@index([e1Id])
  @@index([importBatchId])
  @@index([kostenstelleId, landId, e1Id, jahr, monat])
  @@map("ist_umsatz")
}

// ─────────────── BUDGET ───────────────
model Budget {
  id                String       @id @default(uuid())
  jahr              Int
  monat             Int?
  regionCode        String
  landId            String?
  e1Id              String
  e2Id              String?
  company           Company
  kostentraeger     String?
  wertEur           Decimal?     @db.Decimal(15, 2)
  units             Decimal?     @db.Decimal(15, 2)
  asp               Decimal?     @db.Decimal(15, 4)
  kennzahlTyp       KennzahlTyp  @default(REVENUE)
  istRegionsreserve Boolean      @default(false)
  version           Int          @default(1)
  status            BudgetStatus @default(AKTIV)
  importBatchId     String?
  erstelltAm        DateTime     @default(now())
  aktualisiertAm    DateTime     @updatedAt

  region      Region            @relation(fields: [regionCode], references: [code])
  land        Land?             @relation(fields: [landId], references: [isoCode])
  e1          ProduktgruppeE1   @relation(fields: [e1Id], references: [id])
  e2          ProduktgruppeE2?  @relation(fields: [e2Id], references: [id])
  aenderungen BudgetAenderung[]

  @@index([jahr, monat])
  @@index([regionCode])
  @@index([landId])
  @@index([e1Id])
  @@index([status])
  @@index([jahr, regionCode, landId, e1Id, status])
  @@map("budget")
}

model BudgetAenderung {
  id              String                @id @default(uuid())
  budgetId        String?
  antragstellerId String
  jahr            Int
  regionCode      String
  landId          String?
  e1Id            String
  altWertEur      Decimal?              @db.Decimal(15, 2)
  neuWertEur      Decimal               @db.Decimal(15, 2)
  altUnits        Decimal?              @db.Decimal(15, 2)
  neuUnits        Decimal?              @db.Decimal(15, 2)
  begruendung     String
  status          BudgetAenderungStatus @default(ENTWURF)
  erstelltAm      DateTime              @default(now())

  budget        Budget?                @relation(fields: [budgetId], references: [id])
  antragsteller User                   @relation("Antragsteller", fields: [antragstellerId], references: [id])
  region        Region                 @relation(fields: [regionCode], references: [code])
  land          Land?                  @relation(fields: [landId], references: [isoCode])
  e1            ProduktgruppeE1        @relation(fields: [e1Id], references: [id])
  events        BudgetAenderungEvent[]

  @@index([status])
  @@index([regionCode])
  @@index([antragstellerId])
  @@map("budget_aenderung")
}

model BudgetAenderungEvent {
  id          String                 @id @default(uuid())
  aenderungId String
  vonStatus   BudgetAenderungStatus?
  nachStatus  BudgetAenderungStatus
  byUserId    String
  begruendung String?
  erstelltAm  DateTime               @default(now())

  aenderung BudgetAenderung @relation(fields: [aenderungId], references: [id])
  byUser    User            @relation(fields: [byUserId], references: [id])

  @@index([aenderungId])
  @@map("budget_aenderung_event")
}

// ─────────────── FORECAST ───────────────
model ForecastPeriode {
  id               String         @id @default(uuid())
  periode          String
  jahr             Int
  monat            Int
  regionCode       String
  status           ForecastStatus @default(OFFEN)
  deadline         DateTime
  benachrichtigtAm DateTime?
  erinnerungAm     DateTime?
  eskalationAm     DateTime?
  abgeschlossenAm  DateTime?
  // Fremdüberschreibung durch Vertriebs-/BU-Leitung (Kenntnisnahme durch AGM erforderlich).
  fremdaenderungAm          DateTime?
  fremdaenderungVon         String?
  fremdaenderungBegruendung String?
  fremdaenderungQuittiertAm DateTime?
  erstelltAm       DateTime       @default(now())
  aktualisiertAm   DateTime       @updatedAt

  region Region @relation(fields: [regionCode], references: [code])

  @@unique([periode, regionCode])
  @@index([status])
  @@index([jahr, monat])
  @@map("forecast_periode")
}

model ForecastVersion {
  id                  String         @id @default(uuid())
  periode             String
  jahr                Int
  monat               Int
  regionCode          String
  landId              String
  e1Id                String
  monatswerteRest     Json
  status              ForecastStatus
  kommentar           String?
  schwellwertVerletzt Boolean        @default(false)
  version             Int
  userId              String
  erstelltAm          DateTime       @default(now())

  region Region          @relation(fields: [regionCode], references: [code])
  land   Land            @relation(fields: [landId], references: [isoCode])
  e1     ProduktgruppeE1 @relation(fields: [e1Id], references: [id])
  user   User            @relation(fields: [userId], references: [id])

  @@index([periode, regionCode])
  @@index([regionCode, landId, e1Id])
  @@index([periode, regionCode, landId, e1Id, version])
  @@map("forecast_version")
}

// ─────────────── IMPORT ───────────────
model ImportBatch {
  id                  String       @id @default(uuid())
  typ                 String
  dateiname           String
  hash                String
  monatAbgeschlossen  Boolean      @default(false)
  zeilenGesamt        Int          @default(0)
  zeilenNeu           Int          @default(0)
  zeilenAktualisiert  Int          @default(0)
  zeilenUebersprungen Int          @default(0)
  zeilenQuarantaene   Int          @default(0)
  validierungsbericht Json?
  status              ImportStatus @default(HOCHGELADEN)
  ausgeloestVonId     String
  erstelltAm          DateTime     @default(now())
  abgeschlossenAm     DateTime?

  ausgeloestVon User                        @relation(fields: [ausgeloestVonId], references: [id])
  istUmsaetze   IstUmsatz[]
  quarantaene   ImportQuarantaene[]
  absaetze      Absatz[]
  kundenstamm   Kundenstamm[]
  rechnungen    Verkaufsrechnung[]
  positionen    Verkaufsrechnungsposition[]
  liefermengen  Liefermenge[]

  @@index([hash])
  @@index([status])
  @@map("import_batch")
}

model ImportQuarantaene {
  id             String            @id @default(uuid())
  importBatchId  String
  zeilenNummer   Int
  recid          String?
  rohdaten       Json
  grund          QuarantaeneGrund
  detail         String?
  status         QuarantaeneStatus @default(OFFEN)
  geklaertVonId  String?
  geklaertAm     DateTime?
  klaerKommentar String?
  erstelltAm     DateTime          @default(now())

  importBatch ImportBatch @relation(fields: [importBatchId], references: [id])

  @@index([importBatchId])
  @@index([status])
  @@map("import_quarantaene")
}

// ─────────────── SALES (D365-Import: Kundenstamm + Rechnungen — kundenscharfe Umsatz/Preis/Menge) ───────────────

/// D365-Kundenstamm (CustCustomerV3). Schlüssel = Gesellschaft + Kundennummer (CUSTOMERACCOUNT je DATAAREAID eindeutig).
model Kundenstamm {
  id             String   @id @default(uuid())
  kundennummer   String // CUSTOMERACCOUNT
  dataAreaId     String // DATAAREAID (BBD/BBE/BBF)
  name           String // ORGANIZATIONNAME
  kundengruppe   String? // CUSTOMERGROUPID
  landIso        String? // ADDRESSCOUNTRYREGIONISOCODE
  stadt          String? // ADDRESSCITY
  plz            String? // ADDRESSZIPCODE
  strasse        String? // ADDRESSSTREET
  waehrung       String? // SALESCURRENCYCODE
  typ            String? // CUSTOMERTYPE
  rohdaten       Json // vollständige Exportzeile (311 Spalten) für spätere Auswertung
  importBatchId  String
  erstelltAm     DateTime @default(now())
  aktualisiertAm DateTime @updatedAt

  importBatch ImportBatch @relation(fields: [importBatchId], references: [id])

  @@unique([dataAreaId, kundennummer])
  @@index([landIso])
  @@index([kundengruppe])
  @@map("kundenstamm")
}

/// Rechnungskopf (dboSalesInvoiceHeader). Verknüpft Rechnung → Kunde. Idempotenz über RECID.
model Verkaufsrechnung {
  id              String   @id @default(uuid())
  recid           String   @unique
  rechnungsnummer String // INVOICENUMBER
  dataAreaId      String // DATAAREAID
  kundennummer    String // INVOICECUSTOMERACCOUNTNUMBER
  rechnungsdatum  DateTime // INVOICEDATE_Date
  waehrung        String // CURRENCYCODE
  betragGesamt    Decimal  @db.Decimal(15, 2) // TOTALINVOICEAMOUNT (voller EUR bzw. Originalwährung)
  landIso         String? // INVOICEADDRESSCOUNTRYREGIONISOCODE
  stadt           String? // INVOICEADDRESSCITY
  importBatchId   String
  erstelltAm      DateTime @default(now())

  importBatch ImportBatch @relation(fields: [importBatchId], references: [id])

  @@unique([dataAreaId, rechnungsnummer])
  @@index([kundennummer])
  @@index([rechnungsdatum])
  @@map("verkaufsrechnung")
}

/// Rechnungsposition (dboSalesInvoiceLines). kundennummer + rechnungsdatum aus dem Kopf denormalisiert
/// (Zeitreihen ohne Join). Idempotenz über RECID.
model Verkaufsrechnungsposition {
  id              String   @id @default(uuid())
  recid           String   @unique
  rechnungsnummer String // INVOICENUMBER
  dataAreaId      String // DATAAREAID
  kundennummer    String // denormalisiert aus Verkaufsrechnung
  rechnungsdatum  DateTime // INVOICEDATE_Date
  produktnummer   String? // PRODUCTNUMBER (leer bei Fracht/Provision)
  produktname     String? // PRODUCTNAME / PRODUCTDESCRIPTION
  menge           Decimal  @db.Decimal(15, 2) // INVOICEDQUANTITY
  verkaufspreis   Decimal  @db.Decimal(15, 4) // SALESPRICE (Stückpreis)
  betrag          Decimal  @db.Decimal(15, 2) // LINEAMOUNT
  waehrung        String // CURRENCYCODE
  importBatchId   String
  erstelltAm      DateTime @default(now())

  importBatch ImportBatch @relation(fields: [importBatchId], references: [id])

  @@index([kundennummer, produktnummer, rechnungsdatum])
  @@index([produktnummer])
  @@index([dataAreaId, rechnungsnummer])
  @@map("verkaufsrechnung_position")
}

// ─────────────── AUDIT (append-only) ───────────────
model AuditTrail {
  id          String      @id @default(uuid())
  entitaet    String
  entitaetId  String?
  aktion      AuditAktion
  userId      String?
  userEmail   String?
  vorherWert  Json?
  nachherWert Json?
  ipAdresse   String?
  metadaten   Json?
  erstelltAm  DateTime    @default(now())

  @@index([entitaet, entitaetId])
  @@index([userId])
  @@index([aktion])
  @@index([erstelltAm])
  @@map("audit_trail")
}

// ─────────────── KONFIGURATION ───────────────
model Einstellung {
  key               String   @id
  value             String
  beschreibung      String?
  aktualisiertAm    DateTime @updatedAt
  aktualisiertVonId String?

  @@map("einstellung")
}

model Sondereffekt {
  id              String   @id @default(uuid())
  jahr            Int
  monat           Int?
  regionCode      String?
  landId          String?
  e1Id            String?
  betragEur       Decimal  @db.Decimal(15, 2)
  beschreibung    String
  istEinmaleffekt Boolean  @default(true)
  erstelltVonId   String
  erstelltAm      DateTime @default(now())
  aktualisiertAm  DateTime @updatedAt

  erstelltVon User @relation(fields: [erstelltVonId], references: [id])

  @@index([jahr, monat])
  @@index([regionCode])
  @@map("sondereffekt")
}

// ─────────────── ABSATZ / STÜCKZAHLEN (kunden-/länderscharf, kumuliert je Periode, mit Vorjahr) ───────────────
model Absatz {
  id            String   @id @default(uuid())
  jahr          Int
  bisMonat      Int // kumuliert Jan..bisMonat (z.B. 5 = Jan-Mai)
  landId        String
  kunde         String // SOL_DELIVERYADDRESSNAME
  stadt         String?
  seeds         Decimal  @db.Decimal(15, 2)
  seedsVorjahr  Decimal  @db.Decimal(15, 2)
  ruthen        Decimal  @db.Decimal(15, 2)
  ruthenVorjahr Decimal  @db.Decimal(15, 2)
  icTotal       Decimal  @db.Decimal(15, 2)
  isTotal       Decimal  @db.Decimal(15, 2)
  s16           Decimal  @db.Decimal(15, 2)
  s16Vorjahr    Decimal  @db.Decimal(15, 2)
  details       Json // volle Spalten (IC S06/S17, IS S06/S17, % of Total ...)
  regionCode    String? // beim Import aus KundeRegion-Mapping aufgelöst (null = nicht zugeordnet, nur BU-weit sichtbar)
  importBatchId String
  erstelltAm    DateTime @default(now())

  land        Land        @relation(fields: [landId], references: [isoCode])
  importBatch ImportBatch @relation(fields: [importBatchId], references: [id])

  @@index([jahr, bisMonat])
  @@index([landId])
  @@index([regionCode])
  @@map("absatz")
}

/// Zeilenscharfe Liefermengen (SalesOrderLineitems aus dem ERP-Export). Je (jahr, monat) nach Shipping_Date
/// Voll-Ersatz beim Import. Kein eindeutiger Zeilenschlüssel in der Quelle → keine Upsert-, sondern Perioden-Ersatz-Idempotenz.
model Liefermenge {
  id                String   @id @default(uuid())
  jahr              Int // aus Shipping_Date
  monat             Int // 1..12 aus Shipping_Date (Liefermonat)
  shippingDate      DateTime // tatsächliches Versanddatum
  auftragsnummer    String // SOL_SALESORDERNUMBER
  kunde             String // SO_DELIVERYADDRESSNAME
  landId            String? // SOL_DimensionValue_CountryCode -> Land.isoCode (leer erlaubt)
  regionCode        String? // aus KundeRegion aufgelöst (null = nicht zugeordnet, nur BU-weit sichtbar)
  e1Id              String // SO_Categorie_00 via E1_LOOKUP (unmappbar -> Quarantäne, daher nie null)
  e2Id              String? // SO_Categorie_01 via LIEFERMENGE_E2_LOOKUP
  produktgruppeRoh  String // SO_Categorie_00 roh
  unterkategorieRoh String // SO_Categorie_01 roh
  itemNumber        String // SOL_ITEMNUMBER (SKU)
  stueckzahl        Decimal  @db.Decimal(15, 2) // negative = Retoure/Storno, erhalten
  seedzahl          Decimal  @db.Decimal(15, 2) // negative erhalten
  orderedQty        Decimal? @db.Decimal(15, 2) // Summe von SOL_ORDEREDSALESQUANTITY
  lineAmountEur     Decimal? @db.Decimal(15, 2) // Summe von SOL_LINEAMOUNT
  kostenstelleRoh   String? // Summe von SOL_Kostenstelle (nur roh, keine Region-Auflösung)
  kostentraeger     String? // SOL_Kostenträger
  dataAreaId        String? // SOL_DATAAREAID
  importBatchId     String
  erstelltAm        DateTime @default(now())

  land        Land?            @relation(fields: [landId], references: [isoCode])
  e1          ProduktgruppeE1  @relation(fields: [e1Id], references: [id])
  e2          ProduktgruppeE2? @relation(fields: [e2Id], references: [id])
  importBatch ImportBatch      @relation(fields: [importBatchId], references: [id])

  @@index([jahr, monat])
  @@index([regionCode])
  @@index([landId])
  @@index([e1Id])
  @@index([kunde])
  @@index([importBatchId])
  @@map("liefermenge")
}

// ─────────────── KUNDE → REGION (Admin-pflegbar; ermöglicht AGM-Scoping des Absatzes) ───────────────
model KundeRegion {
  id             String   @id @default(uuid())
  kunde          String   @unique // exakter SOL_DELIVERYADDRESSNAME
  regionCode     String
  erstelltAm     DateTime @default(now())
  aktualisiertAm DateTime @updatedAt

  @@index([regionCode])
  @@map("kunde_region")
}

// ─────────────── AGM-STATEMENTS (strukturierte Vertriebskommentare je Periode/Region) ───────────────
enum AbweichungsGrund {
  KEINE_ABWEICHUNG
  MARKT
  WETTBEWERB
  PREIS
  PROJEKTVERSCHIEBUNG
  REGULATORISCH
  LIEFERFAEHIGKEIT
  EINMALEFFEKT
  SONSTIGES
}

enum StatementStatus {
  ENTWURF
  EINGEREICHT
}

model AgmStatement {
  id                  String           @id @default(uuid())
  periode             String // "JJJJ-MM"
  jahr                Int
  monat               Int
  regionCode          String
  userId              String // erfassender AGM
  userName            String // denormalisiert (Anzeige ohne Join)
  abweichungGrund     AbweichungsGrund @default(KEINE_ABWEICHUNG)
  abweichungKommentar String?
  risiken             String?
  chancen             String?
  pipeline            String?
  kundenGewonnen      String?
  kundenVerloren      String?
  preisWettbewerb     String?
  forecastRealistisch Boolean          @default(true)
  forecastKommentar   String?
  actionItems         Json             @default("[]") // [{beschreibung, faelligBis, erledigt}]
  rueckfragen         Json             @default("[]") // [{id, landId?, e1Id?, frage, frageVon, frageVonName, frageAm, antwort?, antwortVon?, antwortVonName?, antwortAm?, status}] — Klärungs-Dialog BU/VL ↔ AGM
  status              StatementStatus  @default(ENTWURF)
  eingereichtAm       DateTime?
  erstelltAm          DateTime         @default(now())
  aktualisiertAm      DateTime         @updatedAt

  @@unique([periode, regionCode])
  @@index([status])
  @@index([jahr, monat])
  @@map("agm_statement")
}

// ─────────────── PERIODENABSCHLUSS (Monats-Status: Quellen vollständig + abgeglichen + freigegeben) ───────────────
model PeriodenAbschluss {
  id               String    @id @default(uuid())
  jahr             Int
  monat            Int
  abgeschlossen    Boolean   @default(false)
  abgeschlossenVon String?
  abgeschlossenAm  DateTime?
  notiz            String?
  erstelltAm       DateTime  @default(now())
  aktualisiertAm   DateTime  @updatedAt

  @@unique([jahr, monat])
  @@map("perioden_abschluss")
}

// ─────────────── SALES-FLASH-BELEG + RECONCILIATION (Controlling-PDF je Monat) ───────────────
model SalesFlashDokument {
  id               String   @id @default(uuid())
  jahr             Int
  monat            Int // Berichtsmonat (kumuliert Jan..monat)
  dateiname        String
  mimeType         String
  groesseBytes     Int
  inhalt           Bytes // PDF-Binär
  actuals          Json     @default("{}") // {total, regionen:[{regionCode, eur}]}
  kommentar        String?
  hochgeladenVonId String
  hochgeladenVon   String // denormalisiert (E-Mail)
  erstelltAm       DateTime @default(now())
  aktualisiertAm   DateTime @updatedAt

  @@unique([jahr, monat])
  @@index([jahr, monat])
  @@map("sales_flash_dokument")
}

/// Granulare Controlling-Detailwerte aus den Region-Excels (Produktgruppe x Land x Monat), Grundlage
/// des Detail-Abgleichs gegen den Tool-Ist (GL). Voll-Ersatz je (jahr, monat, regionCode) beim Upload.
model SalesFlashDetail {
  id               String   @id @default(uuid())
  jahr             Int // Stand-Jahr des Sales-Flash-Zyklus
  monat            Int // Stand-Monat (Actuals gelten Jan..monat)
  regionCode       String
  e1Id             String
  landId           String?
  periodenMonat    Int // 1-12: Kalendermonat des Actual-Werts
  actualEur        Decimal  @db.Decimal(15, 2)
  produktgruppeRoh String // Excel-Klartext (Nachvollziehbarkeit des Mappings)
  landRoh          String
  dateiname        String
  hochgeladenVon   String // denormalisiert (E-Mail)
  erstelltAm       DateTime @default(now())

  e1   ProduktgruppeE1 @relation(fields: [e1Id], references: [id])
  land Land?           @relation(fields: [landId], references: [isoCode])

  @@unique([jahr, monat, regionCode, e1Id, landId, periodenMonat])
  @@index([jahr, monat, regionCode])
  @@map("sales_flash_detail")
}

// ─────────────── TENDER / AUSSCHREIBUNGEN (fristen-getrieben; Reminder via Scheduler) ───────────────
enum TenderStatus {
  BEOBACHTET
  EINGEREICHT
  GEWONNEN
  VERLOREN
  STORNIERT
}

model Tender {
  id                   String       @id @default(uuid())
  referenznummer       String
  krankenhaus          String // Klinik/Standort (customer_site-Entität folgt in späterer Etappe)
  stadt                String?
  landIso              String? // informativ (kein FK, minimal-invasiv wie agm_statement)
  regionCode           String? // Scoping-Brücke (String ohne FK, analog agm_statement.regionCode)
  veroeffentlichtAm    DateTime?
  abgabefrist          DateTime
  status               TenderStatus @default(BEOBACHTET)
  wettbewerber         String[]     @default([]) // Freitext-Liste (competitor-Stammliste folgt später)
  eigenerPreisEur      Decimal?     @db.Decimal(15, 2) // Preis pro Einheit eigen
  wettbewerbPreisEur   Decimal?     @db.Decimal(15, 2) // Preis pro Einheit Wettbewerb (falls bekannt)
  notiz                String?
  erstelltVonId        String
  erstelltVon          String // denormalisiert (E-Mail, Anzeige ohne Join)
  reminderSchwelleTage Int? // kleinste bereits erinnerte Frist-Schwelle (Reminder-Idempotenz)
  erstelltAm           DateTime     @default(now())
  aktualisiertAm       DateTime     @updatedAt

  lose            TenderLos[]
  reportEintraege ReportEintrag[]
  dokumente       TenderDokument[]

  @@index([status])
  @@index([abgabefrist])
  @@index([regionCode])
  @@map("tender")
}

model TenderLos {
  id          String   @id @default(uuid())
  tenderId    String
  bezeichnung String
  volumenEur  Decimal? @db.Decimal(15, 2)
  menge       Decimal? @db.Decimal(15, 2)
  erstelltAm  DateTime @default(now())

  tender Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  @@index([tenderId])
  @@map("tender_los")
}

// ─────────────── WETTBEWERBER-STAMMLISTE (Pflichtauswahl statt Freitext in Tender/Wettbewerbsbeobachtung) ───────────────
model Competitor {
  id             String   @id @default(uuid())
  name           String   @unique
  aktiv          Boolean  @default(true)
  notiz          String?
  sortierung     Int      @default(0)
  erstelltAm     DateTime @default(now())
  aktualisiertAm DateTime @updatedAt

  reportEintraege ReportEintrag[]

  @@index([aktiv])
  @@map("competitor")
}

// ─────────────── CUSTOMER SITE (Klinik/Standort — via Fuzzy-Match aus Absatz.kunde, manuelle Bestätigung) ───────────────
enum CustomerSiteTyp {
  OEFFENTLICH
  PRIVAT
  UNBEKANNT
}

enum CustomerSiteStatus {
  NEU
  AKTIV
  GEFAEHRDET
  VERLOREN
  ZURUECKGEWONNEN
}

model CustomerSite {
  id             String             @id @default(uuid())
  name           String
  stadt          String?
  landIso        String?
  regionCode     String? // Scoping-Brücke (String ohne FK, analog agm_statement/tender)
  typ            CustomerSiteTyp    @default(UNBEKANNT)
  status         CustomerSiteStatus @default(NEU)
  notiz          String?
  quellNamen     String[]           @default([]) // zugeordnete SOL_DELIVERYADDRESSNAME-Varianten (Matching-Historie)
  d365Konten     String[]           @default([]) // verknüpfte D365-Konten als "<dataAreaId>|<kundennummer>" (Kundenstamm-Abgleich)
  erstelltAm     DateTime           @default(now())
  aktualisiertAm DateTime           @updatedAt

  reportEintraege ReportEintrag[]

  @@index([regionCode])
  @@index([status])
  @@map("customer_site")
}

// ─────────────── MONATSBERICHT VERTRIEB (ersetzt P12F055-Word-Formular; Abschnitte als typisierte Einträge) ───────────────
enum ReportStatus {
  ENTWURF
  IN_PRUEFUNG_KI
  EINGEREICHT
  GELESEN
}

enum ReportAbschnitt {
  KRITISCH
  IMPLANTATION
  AKTIVITAET_NEUKUNDE
  AKTIVITAET_BESTAND
  MARKETING
  PROJEKT
  NAECHSTE_AKTIVITAET
  WETTBEWERB
}

model MonthlyReport {
  id         String       @id @default(uuid())
  periode    String // "JJJJ-MM" (Berichtsmonat)
  jahr       Int
  monat      Int
  regionCode String
  userId     String? // letzter Bearbeiter (AGM)
  userName   String? // denormalisiert (Anzeige ohne Join)
  status     ReportStatus @default(ENTWURF)

  // Abschnitt 5 (Pflicht beim Einreichen): Ausblick des Reps
  forecastFolgemonatEur Decimal? @db.Decimal(15, 2)
  forecastQuartalEur    Decimal? @db.Decimal(15, 2)

  // Abschnitt 7: explizite "keine Veränderung"-Erklärung als Alternative zu Einträgen
  wettbewerbKeineAenderung Boolean @default(false)

  // Abschnitt 8 (optional): Freitexte
  marktAllgemein String?
  personal       String?
  sonstiges      String?

  eingereichtAm DateTime?
  gelesenAm     DateTime?
  gelesenVon    String? // E-Mail des Managers (Lesebestätigung)

  erstelltAm     DateTime @default(now())
  aktualisiertAm DateTime @updatedAt

  eintraege ReportEintrag[]

  @@unique([periode, regionCode])
  @@index([status])
  @@index([jahr, monat])
  @@map("monthly_report")
}

model ReportEintrag {
  id        String          @id @default(uuid())
  reportId  String
  abschnitt ReportAbschnitt
  typ       String? // KRITISCH: TENDER/KUNDENVERLUST/NEUKUNDE/PRODUKTPROBLEM/LIEFERPROBLEM/SONSTIGES · AKTIVITAET_*: BESUCH/TRAINING/MEETING/SUPPORT

  customerSiteId String?
  competitorId   String?
  tenderId       String?
  e1Id           String? // Produktlinien-Bezug (z. B. kritisches Thema je Produktlinie)

  datum        DateTime?
  beschreibung String
  ergebnis     String?

  // Projekt (Abschnitt 5 Projektliste)
  landIso             String?
  stadt               String?
  erwarteterUmsatzEur Decimal? @db.Decimal(15, 2)
  wahrscheinlichkeit  Int? // 0..100 %

  // Marketing
  kostenEur Decimal? @db.Decimal(15, 2)

  // Implantationen je Standort
  menge Decimal? @db.Decimal(15, 2)

  // Wettbewerb
  preisInfo String?

  sortierung Int      @default(0)
  erstelltAm DateTime @default(now())

  report       MonthlyReport    @relation(fields: [reportId], references: [id], onDelete: Cascade)
  customerSite CustomerSite?    @relation(fields: [customerSiteId], references: [id], onDelete: SetNull)
  competitor   Competitor?      @relation(fields: [competitorId], references: [id], onDelete: SetNull)
  tender       Tender?          @relation(fields: [tenderId], references: [id], onDelete: SetNull)
  e1           ProduktgruppeE1? @relation(fields: [e1Id], references: [id])

  @@index([reportId])
  @@index([abschnitt])
  @@index([customerSiteId])
  @@index([tenderId])
  @@map("report_eintrag")
}

// ─────────────── VOICE-DIKTAT (Audio -> STT -> LLM-Extraktion; Zahlen-Guardrail; Audit der KI-Erfassung) ───────────────
enum VoiceStatus {
  TRANSKRIBIERT
  EXTRAHIERT
  BESTAETIGT
  VERWORFEN
}

model VoiceSession {
  id             String      @id @default(uuid())
  periode        String // "JJJJ-MM" (Berichtsmonat, dem das Diktat gilt)
  regionCode     String
  userId         String
  userEmail      String // denormalisiert (Audit)
  sprache        String? // erkannte/gesetzte Sprache (de/en/es/pt/fr)
  status         VoiceStatus @default(TRANSKRIBIERT)
  audio          Bytes? // Rohaufnahme; null nach Löschung gemäß AUDIO_AUFBEWAHRUNG
  audioMimeType  String?
  audioGroesse   Int         @default(0)
  transkript     String // STT-Ergebnis (bleibt als Quelle/Audit erhalten)
  extraktion     Json? // strukturiertes LLM-Ergebnis inkl. Zahlen-Guardrail-Liste
  sttProvider    String?
  llmModell      String?
  bestaetigtAm   DateTime?
  erstelltAm     DateTime    @default(now())
  aktualisiertAm DateTime    @updatedAt

  @@index([periode, regionCode])
  @@index([status])
  @@index([erstelltAm])
  @@map("voice_session")
}

// ─────────────── TENDER-DOKUMENT + KI-ANALYSE (Ausschreibung hochladen -> Claude analysiert -> Tender/Antwortentwurf) ───────────────
enum TenderDokumentStatus {
  HOCHGELADEN
  ANALYSIERT
  UEBERNOMMEN
  VERWORFEN
}

model TenderDokument {
  id               String               @id @default(uuid())
  tenderId         String? // nach Übernahme verknüpft
  dateiname        String
  mimeType         String
  groesseBytes     Int
  inhalt           Bytes // Original (Audit / erneute Analyse)
  status           TenderDokumentStatus @default(HOCHGELADEN)
  analyse          Json? // strukturierte KI-Analyse inkl. Zahlen-Guardrail
  llmModell        String?
  hochgeladenVonId String
  hochgeladenVon   String // denormalisiert (E-Mail)
  regionCode       String? // Scoping-Vorschlag des Uploaders
  erstelltAm       DateTime             @default(now())
  aktualisiertAm   DateTime             @updatedAt

  tender Tender? @relation(fields: [tenderId], references: [id], onDelete: SetNull)

  @@index([tenderId])
  @@index([status])
  @@index([hochgeladenVonId])
  @@map("tender_dokument")
}
