{
  "name": "@forecast/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.cjs --runInBand",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "seed": "ts-node --transpile-only prisma/seed.ts",
    "set-admin": "ts-node --transpile-only scripts/set-admin-password.ts",
    "initial-import": "ts-node --transpile-only scripts/initial-import.ts",
    "verify:ist": "ts-node --transpile-only scripts/verify-ist-import.ts",
    "verify:budget": "ts-node --transpile-only scripts/verify-budget-import.ts",
    "verify:budget-wf": "ts-node --transpile-only scripts/verify-budget-workflow.ts",
    "verify:forecast-wf": "ts-node --transpile-only scripts/verify-forecast-workflow.ts",
    "verify:sales-import": "ts-node --transpile-only scripts/verify-sales-import.ts",
    "verify:kundenabgleich": "ts-node --transpile-only scripts/verify-kundenabgleich.ts",
    "verify:sales-analytik": "ts-node --transpile-only scripts/verify-sales-analytik.ts",
    "verify:sales-ki": "ts-node --transpile-only scripts/verify-sales-ki.ts",
    "verify:dashboard": "ts-node --transpile-only scripts/verify-dashboard.ts",
    "verify:konsolidierung-monatlich": "ts-node --transpile-only scripts/verify-konsolidierung-monatlich.ts",
    "verify:export": "ts-node --transpile-only scripts/verify-export.ts",
    "verify:absatz": "ts-node --transpile-only scripts/verify-absatz.ts",
    "verify:erweiterungen": "ts-node --transpile-only scripts/verify-erweiterungen.ts",
    "verify:tender": "ts-node --transpile-only scripts/verify-tender.ts",
    "verify:customer-site": "ts-node --transpile-only scripts/verify-customer-site.ts",
    "verify:report": "ts-node --transpile-only scripts/verify-report.ts",
    "verify:voice": "ts-node --transpile-only scripts/verify-voice.ts",
    "verify:ki": "ts-node --transpile-only scripts/verify-ki.ts",
    "verify:tender-analyse": "ts-node --transpile-only scripts/verify-tender-analyse.ts"
  },
  "prisma": {
    "seed": "ts-node --transpile-only prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@forecast/shared": "workspace:*",
    "@nestjs/common": "^10.4.4",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.4",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.4",
    "@nestjs/schedule": "^4.1.1",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/terminus": "^10.2.3",
    "@nestjs/throttler": "^6.2.1",
    "@prisma/client": "^5.20.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "csv-parse": "^5.5.6",
    "docx": "^8.5.0",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "helmet": "^8.0.0",
    "nodemailer": "^6.9.15",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.1.4",
    "@nestjs/testing": "^10.4.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.13",
    "@types/node": "^22.7.0",
    "@types/nodemailer": "^6.4.16",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "prisma": "^5.20.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3"
  }
}
