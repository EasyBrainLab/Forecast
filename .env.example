# ─────────────────────────────────────────────────────────────
# Forecast-Portal — ENV-Vorlage (fail-fast validiert, siehe apps/api/src/config/env.validation.ts)
# Kopiere nach .env (dev) bzw. setze als Secrets (prod). .env wird NIE committet.
# ─────────────────────────────────────────────────────────────

# Core
NODE_ENV=development
APP_BASE_URL=http://localhost:3000
DOMAIN=localhost

# Database (lokal: Homebrew-Postgres; prod: docker-compose Service "postgres")
DATABASE_URL=postgresql://dirkwarmuth@localhost:5432/forecast_dev?schema=public

# Auth / Crypto
JWT_SECRET=dev-only-bitte-mindestens-32-zeichen-langes-geheimnis
JWT_EXPIRES_IN=8h
ENCRYPTION_KEY=ZGV2LW9ubHktMzJieXRlLWtleS1iYXNlNjQtZXhhbXBsZQ==
BCRYPT_ROUNDS=12
INVITATION_TOKEN_TTL_DAYS=7
RESET_TOKEN_TTL_HOURS=2
LOCKOUT_MAX_ATTEMPTS=5
LOCKOUT_WINDOW_MIN=30

# SMTP (dev: mailpit auf :1025; prod: echte Zugangsdaten — Bringschuld §0.3)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Forecast-Portal <forecast@localhost>"

# KI / Voice-Diktat (optional — ohne Keys ist das Diktat-Feature deaktiviert, Rest läuft normal)
# LLM-Extraktion: Anthropic Claude (AVV/EU-Hosting laut Datenschutz-Entscheidung 2026-07)
ANTHROPIC_API_KEY=
LLM_MODEL=claude-opus-4-8
# Speech-to-Text: OpenAI Whisper API; Provider: openai | mock (Tests) | leer = aus
OPENAI_API_KEY=
STT_MODEL=whisper-1
STT_PROVIDER=
LLM_PROVIDER=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Seed / Initial-Admin (Bringschuld §0.3)
SEED_ADMIN_EMAIL=admin@localhost
SEED_ADMIN_NAME=System Administrator
ADMIN_INITIAL_PASSWORD=Bitte-Aendern-12!

# Initialdaten (Pfad zu den 3 Realdateien für scripts/initial-import.ts)
DATEN_DIR=.

# Backup
BACKUP_DIR=/var/backups/forecast
BACKUP_RETENTION_DAYS=14

# Zeitzone (Scheduler)
TZ=Europe/Berlin
